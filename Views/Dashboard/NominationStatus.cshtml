@model RAFE.Models.Dashboard
@{
    //ViewBag.Title = "NominationStatus";
    Layout = "~/Views/Shared/_NewLayout.cshtml";
}


@if (RAFE.Utility.WebCommon.GetUserRole(Request.Cookies["UserInfo"]).ToUpper() == "COMM HR")
{
    <div class="container">
        <div class="row">
            <div class="col-sm-12 col-md-4">
                <div class="PieChart">
                    <div>
                        <h3 style="color:white;text-align:center;">Nomination Status</h3>
                    </div>
                    <div id="container" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto;"></div>
                    <!-- ./chart-responsive -->
                </div>
            </div>
            <div class="col-sm-12 col-md-4">
                <div class="PieChart">
                    <div>
                        <h3 style="color:white;text-align:center;">Category Wise Nomination</h3>
                    </div>
                    <div id="container1" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto;"></div>
                    <!-- ./chart-responsive -->
                </div>
            </div>
            <div class="col-sm-12 col-md-4">
                <div class="PieChart">
                    <div class="card-header">
                        <h3 style="color:white;text-align:center;">Total v/s Shortlisted</h3>
                        <div class="card-header-right">
                            <i class="icofont icofont-spinner-alt-5"></i>
                        </div>
                    </div>
                    <div class="card-block">
                        <figure class="highcharts-figure">
                            <div id="container2"></div>
                            <p class="highcharts-description"></p>
                        </figure>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-sm-4">
                <div style="width:105%">
                    @if (Model.lsPieChart.Count > 0)
                    {
                        <!-- Main content -->
                        <section class="content">
                            <div class="box box-danger">
                                <div class="box-header with-border">
                                    <h3 class="box-title">Nomination Status</h3>
                                    <div class="box-tools pull-right">
                                        @using (Html.BeginForm("download1", "Home", FormMethod.Post))
                                        {
                                            <button type="submit" class="fa fa-file fa-file-excel"></button>
                                        }
                                    </div>
                                </div>
                                <div class="box-body">
                                    <div class="row">
                                        <div class="table-responsive">
                                            <table class="table no-margin">
                                                <thead>
                                                    <tr>
                                                        <th>&nbsp; Count</th>
                                                        <th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var status in Model.lsPieChart)
                                                    {
                                                        <tr>
                                                            <td style="color:#72afd2;">&nbsp; @status.y.ToString()</td>
                                                            <td>
                                                                <i class="fa fa-square" style="color: @status.color;"></i>
                                                                <span style="font-size:90% !important;color:#72afd2;">
                                                                    @status.name
                                                                </span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                    else
                    {
                        <section class="content">
                            <div class="box box-danger">
                                <div class="box-header with-border">
                                    <h3 class="box-title">Total v/s Shortlisted</h3>
                                </div>
                                <div class="box-body">
                                    <div class="row">
                                        <div class="table-responsive">
                                            <table class="table no-margin">
                                                <tbody>
                                                    <tr>
                                                        <td>
                                                            <h3>0 Records Found</h3>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                </div>
            </div>
            <div class="col-sm-4">
                <div style="width:105%">
                    @if (Model.PieChart2nd.Count > 0)
                    {
                        <!-- Main content -->
                        <section class="content">
                            <div class="box box-danger">
                                <div class="box-header with-border">
                                    <h3 class="box-title">Category Wise Nomination</h3>

                                    <div class="box-tools pull-right">
                                        @using (Html.BeginForm("download2", "Home", FormMethod.Post))
                                        {
                                            <button type="submit" class="fa fa-file fa-file-excel"></button>
                                        }
                                    </div>
                                </div>
                                <div class="box-body">
                                    <div class="row">
                                        <div class="table-responsive">
                                            <table class="table no-margin">
                                                <thead>
                                                    <tr>
                                                        <th>Count</th>
                                                        <th>Category</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var status in Model.PieChart2nd)
                                                    {
                                                        <tr>
                                                            <td style="color:#72afd2;">@status.y.ToString()</td>
                                                            <td>
                                                                <i class="fa fa-square" style="color: @status.color;"></i>
                                                                <span style="font-size:90% !important;color:#72afd2;">
                                                                    @status.name
                                                                </span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                    else
                    {
                        <section class="content">
                            <div class="box box-danger">
                                <div class="box-header with-border">
                                    <h3 class="box-title">Total v/s Shortlisted</h3>
                                </div>
                                <div class="box-body">
                                    <div class="row">
                                        <div class="table-responsive">
                                            <table class="table no-margin">
                                                <tbody>
                                                    <tr>
                                                        <td>
                                                            <h3>0 Records Found</h3>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                </div>
            </div>
            <div class="col-sm-4">
                <div style="width:105%">
                    @if (Model.List.Count > 0)
                    {
                        <!-- Main content -->
                        <section class="content">
                            <div class="box box-danger">
                                <div class="box-header with-border">
                                    <h3 class="box-title">Total v/s Shortlisted</h3>
                                </div>
                                <div class="box-body">
                                    <div class="row">
                                        <div class="table-responsive">
                                            <table class="table no-margin">
                                                <thead>
                                                    <tr>
                                                        <th style="text-align:center;">Business</th>
                                                        <th style="text-align:center;">Shortlisted Nominations</th>
                                                        <th style="text-align:center;">Nomination</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var business in Model.business)
                                                    {
                                                        <tr>
                                                            <td style="color:#72afd2;text-align:center;">@business.ToString()</td>
                                                            @foreach (var data in Model.List)
                                                            {
                                                                <td style="color:#72afd2;text-align:center;">@data.data.SingleOrDefault()</td>
                                                            }
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                    else
                    {
                        <section class="content">
                            <div class="box box-danger">
                                <div class="box-header with-border">
                                    <h3 class="box-title">Total v/s Shortlisted</h3>
                                </div>
                                <div class="box-body">
                                    <div class="row">
                                        <div class="table-responsive">
                                            <table class="table no-margin">
                                                <tbody>
                                                    <tr>
                                                        <td>
                                                            <h3>0 Records Found</h3>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                </div>
            </div>
        </div>
    </div>

    <script>
        $(window).on('load', function () {
            $(function () {
                Highcharts.chart('container', {
                    chart: {
                        plotBackgroundColor: null,
                        plotBorderWidth: null,
                        plotShadow: false,
                        type: 'pie'
                    },
                    title: {
                        text: ''
                    },
                    tooltip: {
                        pointFormat: '{point.y}'
                    },
                    plotOptions: {
                        pie: {
                            allowPointSelect: true,
                            cursor: 'pointer',
                            dataLabels: {
                                enabled: true,
                                format: '<b>{point.y}</b>',
                                style: {
                                    color: (Highcharts.theme && Highcharts.theme.contrastTextColor) || 'black'
                                }
                            }
                        }
                    },
                    series: [{
                        colorByPoint: true,
                        data: JSON.parse('@Html.Raw(Json.Encode(Model.lsPieChart))')
                    }],
                    credits: {
                        enabled: false
                    }
                });
            });
        });
    </script>
    <script>
        $(window).on('load', function () {
            $(function () {
                Highcharts.chart('container1', {
                    chart: {
                        plotBackgroundColor: null,
                        plotBorderWidth: null,
                        plotShadow: false,
                        type: 'pie'
                    },
                    title: {
                        text: ''
                    },
                    tooltip: {
                        pointFormat: '{point.y}'
                    },
                    plotOptions: {
                        pie: {
                            allowPointSelect: true,
                            cursor: 'pointer',
                            dataLabels: {
                                enabled: true,
                                format: '<b>{point.y}</b>',
                                style: {
                                    color: (Highcharts.theme && Highcharts.theme.contrastTextColor) || 'black'
                                }
                            }
                        }
                    },
                    series: [{
                        colorByPoint: true,
                        data: JSON.parse('@Html.Raw(Json.Encode(Model.PieChart2nd))')
                    }],
                    credits: {
                        enabled: false
                    }
                });
            });
        });
    </script>
}

@section scriptsRef{
    <script src="~/Content/js/Charts/highcharts.js"></script>
}
@section scripts{


    <script>
    function Redirect() {
           window.location = "@Url.Action("Line", "Dashboard")";
        }
    $(window).on('load', function () {
        var theData = JSON.parse('@Html.Raw(Json.Encode(Model.business))');
        console.log(theData);

        $(function () {
            Highcharts.chart('container2', {
                chart: {
                    type: 'column'
                },
                title: {
                    text: '',
                    align: 'left'
                },
                xAxis: {
                    categories: JSON.parse('@Html.Raw(Json.Encode(Model.business))'),
                    labels: {
                        style: {
                            fontSize: '18px',
                        }
                    }
                },
                yAxis: {
                    min: 0,
                    title: {
                        text: 'Count '
                    },
                    stackLabels: {
                        enabled: false,
                        style: {
                            fontWeight: 'bold',
                            color: ( // theme
                                Highcharts.defaultOptions.title.style &&
                                Highcharts.defaultOptions.title.style.color
                            ) || 'gray',
                            textOutline: 'none'
                        }
                    }
                },
                legend: {
                    align: 'left',
                    x: 70,
                    verticalAlign: 'top',
                    y: 20,
                    floating: true,
                    backgroundColor:
                        Highcharts.defaultOptions.legend.backgroundColor || 'white',
                    borderColor: '#CCC',
                    borderWidth: 1,
                    shadow: false
                },

                tooltip: {
                    headerFormat: '<b>{point.x}</b><br/>',
                    pointFormat: '{series.name}: {point.y}<br/>Total : {point.stackTotal}'
                },
                plotOptions: {
                    column: {

                        stacking: 'normal',
                        dataLabels: {
                            enabled: true
                        }
                    }
                },
                colors: [
                    'rgb(46, 216, 182)',
                    'rgb(255, 193, 7)'
                ],

                series: JSON.parse('@Html.Raw(Json.Encode(Model.List))')
            });
        });
    });
    </script>


}

