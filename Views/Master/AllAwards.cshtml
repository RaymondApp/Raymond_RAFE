@model RAFE.Models.AwardMaster

@{
    ViewBag.Title = "Prism Award";
}
<!-- Content Header (Page header) -->
<section class="content-header">
    <h1>
        All Awards
    </h1>
    <ol class="breadcrumb">
        <li><a href="#"><i class="fa fa-dashboard"></i> Home</a></li>
        <li class="active">All Awards</li>
    </ol>
</section>
<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="alert-status" style="display:none">
            @if (TempData["status"] != null)
            {
                if (TempData["status"].ToString() == "1")
                {
                    <label class="lbl-success">@TempData["message"].ToString() </label>
                }
                else
                {
                    <label class="lbl-error">@TempData["message"].ToString() </label>
                }
            }
        </div>
        <div class="col-md-12">
            <div class="box box-danger">
                <!-- /.box-header -->
                <div class="box-body">
                    <div style="margin-bottom: 0px; padding-bottom: 0px; float: right;">
                        @Html.ActionLink("Add New Award", "editaward", "master", null, new { @class = "btn btn-primary", title = "Add New Award" })
                    </div>
                    <br />
                    <br />
                    <div id="divtbl">
                        <table class="table table-bordered" id="tblAwards">
                            <thead>
                                <tr>
                                    <th>Sr No</th>
                                    <th>Award Year</th>
                                    <th>Quarter</th>
                                    <th>Nomination Last Date</th>
                                    <th>Approval Last Date</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AwardMasterList.Count > 0)
                                {
                                    foreach (var item in Model.AwardMasterList)
                                    {
                                        <tr>

                                            <td>@item.SrNo</td>
                                            <td>@item.AwardYear</td>
                                            <td>@item.AwardQuarter</td>
                                            <td>@item.NominationLastDate</td>
                                            <td>@item.ApprovalLastDate</td>
                                            <td>@Html.Raw(RAFE.Utility.WebCommon.GetAwardActiveStatus(item.isActive, item.NominationLastDate))</td>
                                            <td>
                                                <a class="btn btn-primary" text="edit" href="@Url.Action("editaward", "master", new { id = @item.AwardID })">Edit</a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- /.box-body -->
            </div>
        </div>
    </div>
</section>

@section scripts {
    <script>
        $(document).ready(function () {
            $('#tblAwards').DataTable({
                stateSave: true
            });
        });
    </script>

}




