@model RAFE.Models.AwardAdminModel
@{
    ViewBag.Title = "AddEdit";
    Layout = "~/Views/Shared/_NewLayout.cshtml";
}
<style>
    label, .form_text {
        color: white;
    }

    .btn_color {
        background-color: #d8b751;
        border-color: #d8b751;
        color: white;
    }

    table, th, td {
        color: white;
        border: 1px solid white;
        border-collapse: collapse;
    }

    th, td {
        color: white;
        padding: 5px;
        text-align: left;
    }
</style>
    <h2 class="form_text" style="text-align:center">EDIT</h2>
    <div class="container">
        @{
            string name = Model.AwardName;
            string[] str1;
            string award_name = "";
            string award_desc = "";
            if (name.Contains('-'))
            {
                str1 = name.Split(new char[] { '-' });
                award_name = str1[0];
                if (str1.Length == 2)
                {
                    award_desc = str1[1];
                }
                else if (str1.Length == 3)
                {
                    award_desc = str1[1] + '-' + str1[2];
                }
                else
                {
                    award_desc = "";
                }
            }
            else
            {
                award_name = Model.AwardName;
            }
        }

        <table style="width:100%">
            <tr>
                <th>Award Type ID</th>
                <td><label for="awardtypeid">@Model.AwardTypeID</label></td>
            </tr>
            <input id="id" type="hidden" value="@Model.AwardTypeID" />
            <tr>
                <th>Award Category</th>
                <td><label for="awardcategory">@Model.AwardCategory</label></td>
            </tr>
            <tr>
                <th>Award Name</th>
                <td>@Html.TextBox("Award Name",award_name,new { style ="color:black",size = 60, id="name"})</td>
            </tr>
            <tr>
                <th>Award Description</th>
                <td>@Html.TextBox("Award Description",award_desc, new { style = "color:black", size = 60 , id="desc"})</td>
            </tr>

        </table>
        <br /><br />
        <div class="col-md-12 text-center">
            <button type="button" title="Save" id="submit" value="Save" class="btn btn_color">SAVE</button>
            <a class="btn btn_color" href="@Url.Action("AdminPage", "Home")">BACK</a>
        </div>
    </div>
<script>
    $('#submit').click(function () {
        $.ajax({
            url: "@Url.Action("AwardName_Update","Home")",
            type: "Post",
            data: { awardtypeid: $('#id').val(), awardname: $('#name').val(), awarddesc: $('#desc').val() },
            success: function (result) {
                window.location.href = '@Url.Action("AdminPage","Home")';
            },
            error: function () {
            }
        })
    })
</script>