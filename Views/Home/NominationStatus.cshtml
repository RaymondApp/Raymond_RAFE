@model RAFE.Models.Dashboard
@{
    //ViewBag.Title = "NominationStatus";
    Layout = "~/Views/Shared/_NewLayout.cshtml";
}

<div class="row">
    <div class="col-sm-6 PieChart">
        <div> <h3 style="color:white">   &nbsp; &nbsp;  &nbsp;    Nomination </h3>    </div>
        <div id="container" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto"></div>
        <!-- ./chart-responsive -->
    </div>
    <div class="col-sm-6 PieChart">
        <div> <h3 style="color:white">      &nbsp; &nbsp;  &nbsp;   Award  </h3>    </div>
        <div id="container1" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto"></div>
        <!-- ./chart-responsive -->
    </div>
</div>
<div class="row">
    <table style="margin-top:10px; margin-left:28px">
        <tr>
            <td valign="top" style="width:631px;height:700px">
                <div>
                    @if (Model.lsPieChart.Count > 0)
                    {
                        <!-- Main content -->
                        <section class="content">
                            <div class="box box-danger">
                                <div class="box-header with-border">
                                    <h3 class="box-title">Nomination Status</h3>
                                    <div class="box-tools pull-right">
                                        @using (Html.BeginForm("download1", "Home", FormMethod.Post))
                                        {
                                            <button type="submit" class="fa fa-file fa-file-excel"></button>
                                        }
                                    </div>
                                </div>
                                <div class="box-body">
                                    <div class="row">
                                        <div>
                                            <div class="table-responsive">
                                                <table class="table no-margin">
                                                    <thead>
                                                        <tr>
                                                            <th>&nbsp; Count</th>
                                                            <th>Status</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var status in Model.lsPieChart)
                                                        {
                                                            <tr>
                                                                <td style="color:#72afd2;">&nbsp; @status.y.ToString()</td>
                                                                <td>
                                                                    <i class="fa fa-square" style="color: @status.color;"></i>
                                                                    <span style="font-size:90% !important;color:#72afd2;">
                                                                        @status.name
                                                                    </span>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                </div>
            </td>
            <td style="width:57px"></td>
            <td valign="top" style="width:631px">
                <div>

                    @if (Model.PieChart2nd.Count > 0)
                    {

                        <!-- Main content -->
                        <section class="content">
                            <div class="box box-danger">
                                <div class="box-header with-border">
                                    <h3 class="box-title">Award Type Status</h3>

                                    <div class="box-tools pull-right">
                                        @using (Html.BeginForm("download2", "Home", FormMethod.Post))
                                        {
                                        <button type="submit" class="fa fa-file fa-file-excel"></button>
                                        }
                                    </div>
                                </div>
                                <div class="box-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="table-responsive">
                                                <table class="table no-margin">
                                                    <thead>
                                                        <tr>
                                                            <th>Count</th>
                                                            <th>Status</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var status in Model.PieChart2nd)
                                                        {
                                                            <tr>
                                                                <td style="color:#72afd2;">@status.y.ToString()</td>
                                                                <td>
                                                                    <i class="fa fa-square" style="color: @status.color;"></i>
                                                                    <span style="font-size:90% !important;color:#72afd2;">
                                                                        @status.name
                                                                    </span>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                        <div class="col-md-5 PieChart">
                                            <div id="container1" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto"></div>
                                            <!-- ./chart-responsive -->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                </div>
            </td>
        </tr>
    </table>
</div>
@section scriptsRef{
    <script src="~/Content/js/Charts/highcharts.js"></script>
}
@section scripts{
    <script>
        $(window).on('load', function () {
            $(function () {
                Highcharts.chart('container', {
                    chart: {
                        plotBackgroundColor: null,
                        plotBorderWidth: null,
                        plotShadow: false,
                        type: 'pie'
                    },
                    title: {
                        text: ''
                    },
                    tooltip: {
                        pointFormat: '{point.y}'
                    },
                    plotOptions: {
                        pie: {
                            allowPointSelect: true,
                            cursor: 'pointer',
                            dataLabels: {
                                enabled: true,
                                format: '<b>{point.y}</b>',
                                style: {
                                    color: (Highcharts.theme && Highcharts.theme.contrastTextColor) || 'black'
                                }
                            }
                        }
                    },
                    series: [{
                        colorByPoint: true,
                        data: JSON.parse('@Html.Raw(Json.Encode(Model.lsPieChart))')
                    }],
                    credits: {
                        enabled: false
                    }
                });
            });
        });
    </script>
    <script>
        $(window).on('load', function () {
            $(function () {
                Highcharts.chart('container1', {
                    chart: {
                        plotBackgroundColor: null,
                        plotBorderWidth: null,
                        plotShadow: false,
                        type: 'pie'
                    },
                    title: {
                        text: ''
                    },
                    tooltip: {
                        pointFormat: '{point.y}'
                    },
                    plotOptions: {
                        pie: {
                            allowPointSelect: true,
                            cursor: 'pointer',
                            dataLabels: {
                                enabled: true,
                                format: '<b>{point.y}</b>',
                                style: {
                                    color: (Highcharts.theme && Highcharts.theme.contrastTextColor) || 'black'
                                }
                            }
                        }
                    },
                    series: [{
                        colorByPoint: true,
                        data: JSON.parse('@Html.Raw(Json.Encode(Model.PieChart2nd))')
                    }],
                    credits: {
                        enabled: false
                    }
                });
            });
        });
    </script>
}

