@model RAFE.Models.Dashboard
@{
    ViewBag.Title = "AwardStatus";
    Layout = "~/Views/Shared/_NewLayout.cshtml";
}




@if (Model.lsPieChart.Count > 0)
{
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <ol class="breadcrumb">
            <li><a href="@Url.Action("Index","Home")"><i class="fa fa-dashboard"></i> Home</a></li>
            <li class="active">Dashboard</li>
        </ol>
        @*<style>
                .PieChart {
                    padding-top: 10%;
                }
            </style>*@
    </section>
    <!-- Main content -->
    <section class="content">
        <div class="box box-danger">
            <div class="box-header with-border">
                <h3 class="box-title">Nomination Status</h3>
                <div class="box-tools pull-right">
                    <button type="button" class="btn btn-box-tool" data-widget="collapse">
                        <i class="fa fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="table-responsive">
                            <table class="table no-margin">
                                <thead>
                                    <tr>
                                        <th>Count</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var status in Model.lsPieChart)
                                    {
                                        <tr>
                                            <td style="color:#72afd2;">@status.y.ToString()</td>
                                            <td>
                                                <i class="fa fa-square" style="color: @status.color;"></i>
                                                <span style="font-size:90% !important;color:#72afd2;">
                                                    @status.name
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="col-md-5 PieChart">
                        <div id="container" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto"></div>
                        <!-- ./chart-responsive -->
                    </div>
                </div>
            </div>
        </div>
    </section>
    @section scriptsRef{
        <script src="~/Content/js/Charts/highcharts.js"></script>
    }
    @section scripts{
        <script>
        $(window).on('load', function () {
            $(function () {
                Highcharts.chart('container', {
                    chart: {
                        plotBackgroundColor: null,
                        plotBorderWidth: null,
                        plotShadow: false,
                        type: 'pie'
                    },
                    title: {
                        text: ''
                    },
                    tooltip: {
                        pointFormat: '{point.y}'
                    },
                    plotOptions: {
                        pie: {
                            allowPointSelect: true,
                            cursor: 'pointer',
                            dataLabels: {
                                enabled: true,
                                format: '<b>{point.y}</b>',
                                style: {
                                    color: (Highcharts.theme && Highcharts.theme.contrastTextColor) || 'black'
                                }
                            }
                        }
                    },
                    series: [{
                        colorByPoint: true,
                        data: JSON.parse('@Html.Raw(Json.Encode(Model.lsPieChart))')
                    }],
                    credits: {
                        enabled: false
                    }
                });
            });
        });
        </script>
    }
}

