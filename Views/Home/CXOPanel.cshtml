@model RAFE.Models.NominationModel


<!-- Content Header (Page header) -->
<section class="content-header">
    <h1>
        CXO Panel
    </h1>
    <ol class="breadcrumb">
        <li><a href="#"><i class="fa fa-dashboard"></i> Home</a></li>
        <li class="active">CXO Panel</li>
    </ol>
</section>
<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="alert-status" style="display:none">
            @if (TempData["status"] != null)
            {
                if (TempData["status"].ToString() == "1")
                {
                    <label class="lbl-success">@TempData["message"].ToString() </label>
                }
                else
                {
                    <label class="lbl-error">@TempData["message"].ToString() </label>
                }
            }
        </div>
        <div class="col-md-12">
            <div class="box box-danger">
                <!-- /.box-header -->
                <div class="box-body">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="row">
                            <div class="col-md-12">
                                <div class="col-md-2 col-sm-6">
                                    <label>By Award Type</label>
                                </div>
                                <div class="col-md-3 col-sm-6">
                                    <div class="form-group">
                                        @Html.DropDownListFor(m => Model.AwardTypeId, new SelectList(ViewBag.AwardsType, "AwardTypeID", "AwardType"), "--Select type--", new { @id ="ddlAwardType", @class = "form-control select2", style = "width: 100%;", required = "required" })
                                    </div>
                                </div>
                                <div class="col-md-2 col-sm-6">
                                    <label>By Function</label>
                                </div>
                                <div class="col-md-3 col-sm-6">
                                    <div class="form-group">
                                        @Html.DropDownList("ddlFunctions", new SelectList(ViewBag.Functions), "--Select function--", new { @class = "form-control select2", style = "width: 100%;", required = "required" })
                                    </div>
                                </div>
                                <div class="form-group has-error" style="margin-left: 0px !important;">
                                    <label id="lblPRError" class="control-label" for="txtPRNo"></label>
                                </div>
                            </div>
                        </div>
                    </form>
                    <hr />
                    <div id="tbl_list">
                        @Html.Partial("_nominationList", Model)
                    </div>
                </div>
                <!-- /.box-body -->
            </div>
        </div>
    </div>
</section>


@section scripts {
    <script>
        var var_js = function () {
            $div = $("#tbl_list");
            $table = $('#tblAwards');
            return {
                init: function () {
                    var_js.registerGetListEvents();
                    if ($table.length > 0) {
                        var_js.initDataTable($table);
                    }
                },
                registerGetListEvents: function () {
                    $('#ddlFunctions').on("change", function () {
                        $('.loading').show();
                        functionName = $(this).val();
                        AwardTypeID = $("#ddlAwardType").val();

                        App.getView("Award List", "POST", url_param.postURL, { functionName: functionName, AwardTypeID: AwardTypeID }, $div, function (result) {
                            if ($('#tblAwards').length > 0) {
                                var_js.initDataTable($('#tblAwards'));
                                $('.loading').hide();
                            }
                        }, function (error) {

                        });
                    });

                    $('#ddlAwardType').on("change", function () {
                        $('.loading').show();
                        functionName = $("#ddlFunctions").val();
                        AwardTypeID = $(this).val();
                        App.getView("Award List", "POST", url_param.postURL, { functionName: functionName, AwardTypeID: AwardTypeID }, $div, function (result) {
                            if ($('#tblAwards').length > 0) {
                                var_js.initDataTable($('#tblAwards'));
                                $('.loading').hide();
                            }
                        }, function (error) {

                        });
                    });
                },
                initDataTable: function ($table) {
                    $table.DataTable({
                        stateSave: true,
                        responsive: true
                    });
                },
            };
        }();

        $(document).ready(function () {
            url_param = {};
            url_param.postURL = '@Url.Action("cxopanel", "home")';            
            var_js.init();
        });
    </script>

}