@model RAFE.Models.GiveFeedBack

@{
    Layout = "~/Views/Shared/_NewLayout.cshtml";
    ViewBag.Title = "RAFE All Nomination";

}

<style>
    .form_text {
        color: white;
    }
</style>
<!-- Content Header (Page header) -->
<section class="content-header">
    <h1 class="form_text">
        All Required Feedback(s)
    </h1>
    @*<ol class="breadcrumb">
            <li><a href="#"><i class="fa fa-dashboard"></i> Home</a></li>
            <li class="active">All Nomination(s)</li>
        </ol>*@
</section>
<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="col-md-12" style="background-color:white;">
            <div class="box box-danger">
                <!-- /.box-header -->
                <div class="box-body">
                    <div class="row">
                        <div id="divtbl" style="overflow-x:scroll">
                            <table class="table table-bordered table-responsive" id="tblFeedbacks">
                                <thead>
                                    <tr>
                                        <td>SrNo</td>
                                        <th>Nomination ID</th>
                                        <th>Nominee</th>
                                        <th>Award Type</th>
                                        <th>Award Category</th>
                                        <th>Award Year</th>
                                        <th>Function Name</th>
                                        <th>Question</th>
                                        <th>Feedback</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                        @*<th>Award Category</th>
        <th style="width: 80px !important;">Award Type</th>
        <th>Function</th>
        <th style="width: 120px !important;">Nominated By</th>
        <th width="20%">Nominee</th>
        <th>Status</th>
        <th>Action</th>*@
                                    </tr>
                                </thead>
                                <tbody>


                                    @foreach (var item in Model.GiveFeedBackList)
                                    {
                                        <tr>
                                            <td>@item.SrNo</td>
                                            <td>@item.NominationId</td>
                                            <th>@item.Nominee</th>
                                            <td>@item.AwardType</td>
                                            <td>@item.AwardCategory</td>
                                            <td>@item.AwardYear</td>
                                            <td>@item.FunctionName</td>
                                            <td>@item.AskFeedback</td>
                                            <td>@item.GiveFeedback</td>
                                            <td>@item.CurrentStatus</td>
                                            @if (item.CurrentStatus != null || item.CurrentStatus!="")
                                            {
                                                <td>
                                                    <a class="someclass" data-id="@item.NominationId">Give Feedback</a>
                                                </td>
                                            }
                                        </tr>
                                     }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- /.box-body -->
            </div>
        </div>
    </div>
    <form id="formInfo" target="_blank" action="@Url.Action("DataDownload","Common")" method="post">
        <input type="hidden" id="year" name="year" value="0">
        <input type="hidden" id="category" name="category" value="0">
        <input type="hidden" id="master" name="master" value="0">
        <input type="hidden" id="subcategory" name="subcategory" value="0">
    </form>
</section>
<div id="partialModal" class="modal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="text-center modal-title" id="nomDtl">Feedback</h3>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal" onclick="close()">Close</button>
            </div>
        </div>
    </div>
</div>
@Scripts.Render("~/bundles/jqueryval")
<script>
    $(document).ready(function () {
        $('#tblFeedbacks').DataTable({
            stateSave: true
        });
        $("#Filter").html(' ');
    });
    $(function () {
        $('[data-toggle="popover"]').popover()
    })
    //Saurabh Kumar Date- 19/05/2023
    $(document).on('click', 'a[name=lnkViews]', function (e) {
        /* do work */
    });
    $('a.someclass').click(function () {
        $.ajax({
            url: "@Url.Action("SendFeedBack", "Home")",
            type: "Post",
            data: { nominationId: $(this).data('id') },
            success: function (response) {
                $("#partialModal").find(".modal-body").html(response);
                $("#partialModal").modal('show');
                //$("#partialModal").show();
            },
            error: function (xrh) {
            }
        });
    });
</script>