@section scripts
{
    <script>
        $(document).ready(function () {
            if (parseInt($('#isSubmitted').val()) == 1) {
                $('.form-control').attr("disabled", "disabled");
                $('input[type=radio]').attr("disabled", "disabled");
                $('#btnSave').hide();
                $('#btnSubmitt').hide();
                $('input[type=file]').hide();
            }

            $('#btnSave').click(function () {
                $('.loading').show();
                $('#isSubmitted').val(0);
                var form = $("#form_nomination");
                form.validate();
                if (form.valid()) {
                    form.submit();
                }
                else {
                    $('.loading').hide();
                }

            });
            $('#btnSubmitt').click(function () {
                $('.loading').show();
                $('#isSubmitted').val(1);

                var form = $("#form_nomination");
                form.validate();
                if (form.valid()) {
                    form.submit();
                }
                else {
                    $('.loading').hide();
                }

            });
        });
    </script>
}