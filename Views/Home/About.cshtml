                        @Html.HiddenFor(m => Model.NominatorDetails.Description)
                    </div>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-12">
                    <div class="col-md-3 col-sm-3">
                        <label>Function</label>
                    </div>
                    <div class="col-md-9 col-sm-9">
                        <label class="label-box">
                            @Model.NominatorDetails.Department
                        </label>
                        @Html.HiddenFor(m => Model.NominatorDetails.Department)
                    </div>
                </div>
            </div>


            <div class="row">
                <div class="col-lg-4 col-md-4 col-sm-12">
                    <div class="col-md-3 col-sm-3">
                        <label>Mobile No</label>
                    </div>
                    <div class="col-md-9 col-sm-9">
                        <label class="label-box">
                            @Model.NominatorDetails.OfficePhone
                        </label>
                        @Html.HiddenFor(m => Model.NominatorDetails.OfficePhone)
                    </div>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-12">
                    <div class="col-md-3 col-sm-3">
                        <label>EmailID</label>
                    </div>
                    <div class="col-md-9 col-sm-9">
                        <label class="label-box">
                            @Model.NominatorDetails.EmailAddress
                        </label>
                        @Html.HiddenFor(m => Model.NominatorDetails.EmailAddress)
                    </div>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-12">
                    <div class="col-md-3 col-sm-3">
                        <label>Designation</label>
                    </div>
                    <div class="col-md-9 col-sm-9">
