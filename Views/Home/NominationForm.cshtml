                                            <label class="form_text" id="lbl_award_cat_@Model.AwardCategoryList[i].AwardCategoryId" for="rbAward_@Model.AwardCategoryList[i].AwardCategoryId">
                                                <input type="radio" value="@Model.AwardCategoryList[i].AwardCategoryId" name="AwardCategory" id="rbAward_@Model.AwardCategoryList[i].AwardCategoryId" @if (Model.NominationID == 0 && i == 0) { <text> checked="checked" </text>  } else if (Model.AwardCategory == Model.AwardCategoryList[i].AwardCategoryId) { <text> checked="checked" </text> } />
                                                <img width="85" id="img_award_cat_@Model.AwardCategoryList[i].AwardCategoryId" src="@RAFE.Utility.WebCommon.GetApplicationAbsolutePath()/Content/img/award_catnew_@Model.AwardCategoryList[i].AwardCategoryId-.png">
                                            </label>
                                        </div>

                                    }

                                }
