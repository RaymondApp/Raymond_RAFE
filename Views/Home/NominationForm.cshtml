                                <label class="form_text">All fields marked as (<span style="color:red">*</span>) are mandatory </label>
                            </div>
                        </div>
                        <div class="no-print">
                            <div class="callout raf-callout-info callout-info" style="margin-bottom: 5px!important;">
                                @* <h4>Award Detail</h4>*@<h4> &nbsp; </h4>
                            </div>
                        </div>
                    </div>
                </div>
