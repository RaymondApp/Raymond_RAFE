@model RAFE.Models.AwardModel

@{
    Layout = "~/Views/Shared/_NewLayout.cshtml";
    ViewBag.Title = "RAFE Nomination Form";
    string isCXO = "False";
    if (Request.QueryString["iscxo"] != null)
    {
        isCXO = Request.QueryString["iscxo"].ToString();
    }

}
<style>
    label,.form_text{
        color:white;
    }
    .text-danger{
        color:black;
    }
</style>


<!-- Content Header (Page header) -->
<!-- Main content -->
@if (Model.validUser)
{
    @Html.HiddenFor(m => m.NominationID, new { @id = "hdNominationID" })
    <section class="content">
        <form method="post" enctype="multipart/form-data" id="form_nomination" action="@Url.Action("NominationForm", "Home", new { iscxo = isCXO })">
            <div class="row">
                <div class="alert-status" style="display:none">
                    @if (TempData["status"] != null)
                    {
                        if (TempData["status"].ToString() == "1")
                        {
                            <label class="lbl-success">@TempData["message"].ToString() </label>
                        }
                        else
                        {
                            <label class="lbl-error">@TempData["message"].ToString() </label>
                        }
                    }
                </div>
                @*@Html.ValidationSummary(false)*@
                <div class="row collapse">
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <div class="col-md-3 col-sm-3">
                            <label>Name</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <label class="label-box">
                                @Model.NominatorDetails.Name
                            </label>
                            @Html.HiddenFor(m => Model.NominatorDetails.SamAccountName)
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <div class="col-md-3 col-sm-3">
                            <label>EmployeeID</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <label class="label-box">
                                @Model.NominatorDetails.Description
                            </label>
                            @Html.HiddenFor(m => Model.NominatorDetails.Description)
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <div class="col-md-3 col-sm-3">
                            <label>Function</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <label class="label-box">
                                @Model.NominatorDetails.Department
                            </label>
                            @Html.HiddenFor(m => Model.NominatorDetails.Department)
                        </div>
                    </div>
                </div>


                <div class="row collapse">
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <div class="col-md-3 col-sm-3">
                            <label>Mobile No</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <label class="label-box">
                                @Model.NominatorDetails.OfficePhone
                            </label>
                            @Html.HiddenFor(m => Model.NominatorDetails.OfficePhone)
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <div class="col-md-3 col-sm-3">
                            <label>EmailID</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <label class="label-box">
                                @Model.NominatorDetails.EmailAddress
                            </label>
                            @Html.HiddenFor(m => Model.NominatorDetails.EmailAddress)
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <div class="col-md-3 col-sm-3">
                            <label>Designation</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <label class="label-box">
                                @Model.NominatorDetails.Title
                            </label>
                        </div>
                    </div>
                </div>
                <div class="row collapse">
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <div class="col-md-3 col-sm-3">
                            <label>Year</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <div class="form-group">
                                @*@Html.DropDownListFor(m => Model.AwardYear, new SelectList(Model.AwardYearList), new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => Model.AwardYear, "", new { @class = "text-danger  " })*@
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-12" style="display:none">
                        <div class="col-md-3 col-sm-3">
                            <label>Biannual</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <div class="form-group dropdown_text">
                                @Html.DropDownListFor(m => Model.AwardQuarter, new SelectList(Model.AwardQuarterList), new { @class = "form-control dropdown_text", required = "required" })
                                @Html.ValidationMessageFor(m => Model.AwardQuarter, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <div class="col-md-3 col-sm-3">
                            <label>Business</label>
                        </div>
                        <div class="col-md-9 col-sm-9">
                            <label class="label-box">
                                @Model.NominatorDetails.Company
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            @if ((Model.AwardYearList != null && Model.AwardYearList.Count > 0) || Model.isSubmitted == 1 || Model.isSubmitted == -1)
