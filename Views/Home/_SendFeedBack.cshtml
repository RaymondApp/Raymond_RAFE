        <br />
        <div>
        </div>
    </div>

</body>
<script type="text/javascript">
    $('.loading').hide();
    //$('#btnSendMail').click(function () {
    $('#btnSendFeedback').click(function (event) {
        var txtVal = $("#question").val();
        var id = $(this).data('id');
        swal($("#question").val());
        if ($('#question').val() == "") {
            swal('!Please Give Any Feedback');
        } else {
            $.ajax({
                url: "@Url.Action("SaveFeedback", "Home")",
                type: "Post",
                data: { GiveFeedback: $("#question").val() },
                success: function (response) {
                   alert('Data Save Sucessfully');
                    //swal('Data Save Sucessfully');
                    window.location.href = "http://localhost:65337/home/GiveFeedBack";
                    //$("#partialModal").find(".modal-body").html(response);
                    //$("#partialModal").modal('show');
                    //$("#partialModal").show();

                },
                error: function (xrh) {
                }
            });
        }
        //swal('Data Save Sucessfully');
    });
</script>
