<style>
    .formfield {
        display: flex;
        align-items: center;
    }

    button#btnSave, button#Approved, button#btnAddEmp, button#btnApproved, button#btnReject {
        background-color: #d8b751;
        border-color: #d8b751;
    }

    button#btnSubmitt, button#btnRemoveEmp, button#btnNMI {
        background-color: #9A792C;
        border-color: #9A792C;
    }

    .voice {
        height: auto;
    }
</style>
<body>
    <div class="container-fluid">
        <div class="formfield" id="input-single">
            <label id="askFeedback">Feedback :</label>
            @Html.TextAreaFor(m => m.GiveFeedback, new { @id = "question", @placeholder = "Create a new note by typing or using voice command", @rows = "5", @cols = "60" })
        </div>
        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
